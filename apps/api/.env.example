# Application
NODE_ENV="development"
PORT=4000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pml_cms?schema=public"

# Comma-separated frontend origin allowlist.
# Required when NODE_ENV=production.
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="replace-with-a-random-secret-at-least-32-characters-long"
JWT_EXPIRES_IN="8h"

# Initial admin account.
# Use only during first local or staging/production initialization.
ADMIN_SEED_NAME="PML Admin"
ADMIN_SEED_EMAIL="admin@pharmametriclabs.com"
ADMIN_SEED_PASSWORD="<set-a-strong-one-time-admin-password>"
