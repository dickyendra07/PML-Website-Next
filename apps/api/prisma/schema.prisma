generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InquiryStatus {
  NEW
  IN_REVIEW
  CONTACTED
  CLOSED
  SPAM
}

enum PopupType {
  ANNOUNCEMENT
  PROMOTION
  ALERT
  INFORMATION
}

enum PopupLayout {
  IMAGE_LEFT
  IMAGE_RIGHT
  IMAGE_TOP
  TEXT_ONLY
}

enum PopupFrequency {
  ONCE_PER_SESSION
  ONCE_PER_DAY
  ALWAYS
}

enum MediaType {
  IMAGE
  DOCUMENT
  VIDEO
  OTHER
}

enum CatalogueDownloadMode {
  PUBLIC_DOWNLOAD
  REQUEST_REQUIRED
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role])
  @@index([isActive])
}

model ProposalSubmission {
  id           String        @id @default(cuid())
  name         String
  company      String
  email        String
  phone        String?
  country      String?
  serviceType  String
  projectNeeds String
  sourcePage   String?
  status       InquiryStatus @default(NEW)
  internalNote String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt

  @@index([status])
  @@index([serviceType])
  @@index([createdAt])
}

model ContactInquiry {
  id           String        @id @default(cuid())
  name         String
  company      String?
  email        String
  service      String?
  message      String
  status       InquiryStatus @default(NEW)
  sourcePage   String?
  internalNote String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt

  @@index([status])
  @@index([service])
  @@index([createdAt])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  value       Json
  group       String   @default("general")
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@index([isPublic])
}

model PopupAnnouncement {
  id             String         @id @default(cuid())
  title          String
  description    String?
  buttonLabel    String?
  buttonUrl      String?
  imageUrl       String?
  layout         PopupLayout    @default(IMAGE_LEFT)
  type           PopupType      @default(ANNOUNCEMENT)
  status         PublishStatus  @default(DRAFT)
  placementPages String[]       @default(["/"])
  frequency      PopupFrequency @default(ONCE_PER_SESSION)
  startsAt       DateTime?
  endsAt         DateTime?
  priority       Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@index([priority])
}

model CatalogueItem {
  id           String                @id @default(cuid())
  title        String
  slug         String                @unique
  description  String?
  serviceType  String?
  fileUrl      String?
  coverImage   String?
  downloadMode CatalogueDownloadMode @default(REQUEST_REQUIRED)
  status       PublishStatus         @default(DRAFT)
  sortOrder    Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  requests CatalogueRequest[]

  @@index([status])
  @@index([serviceType])
  @@index([sortOrder])
}

model CatalogueRequest {
  id          String        @id @default(cuid())
  catalogueId String?
  name        String
  company     String?
  email       String
  phone       String?
  message     String?
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  catalogue CatalogueItem? @relation(fields: [catalogueId], references: [id], onDelete: SetNull)

  @@index([catalogueId])
  @@index([status])
  @@index([createdAt])
}

model InsightPost {
  id String @id @default(cuid())

  titleEn           String?
  slugEn            String?  @unique
  excerptEn         String?
  contentEn         String?
  tagsEn            String[] @default([])
  seoTitleEn        String?
  metaDescriptionEn String?

  titleId           String?
  slugId            String?  @unique
  excerptId         String?
  contentId         String?
  tagsId            String[] @default([])
  seoTitleId        String?
  metaDescriptionId String?

  category    String
  coverImage  String?
  status      PublishStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([publishedAt])
}

model HomepageFeature {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        String
  referenceId String?
  imageUrl    String?
  buttonLabel String?
  buttonUrl   String?
  status      PublishStatus @default(DRAFT)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@index([status])
  @@index([sortOrder])
}

model MediaAsset {
  id           String    @id @default(cuid())
  filename     String
  originalName String?
  mimeType     String?
  size         Int?
  url          String
  type         MediaType @default(OTHER)
  altText      String?
  caption      String?
  folder       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type])
  @@index([folder])
  @@index([createdAt])
}

model CareerPost {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  department       String?
  location         String?
  employmentType   String?
  experienceLevel  String?
  summary          String?
  description      String?
  responsibilities String?
  requirements     String?
  benefits         String?
  applyEmail       String?
  applyUrl         String?
  status           PublishStatus @default(DRAFT)
  sortOrder        Int           @default(0)
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([department])
  @@index([sortOrder])
  @@index([publishedAt])
}

model PageSeo {
  id            String        @id @default(cuid())
  path          String        @unique
  label         String
  title         String
  description   String
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  canonicalUrl  String?
  status        PublishStatus @default(PUBLISHED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([path])
}
